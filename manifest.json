{
  "manifest_version": 2,
  "name": "Cyber Privacy Inspector",
  "version": "0.2.0",
  "description": "Extensão Firefox para detectar rastreamento, cookies, storage, fingerprint e riscos à privacidade.",
  "icons": {
    "48": "icons/icon.png"
  },
  "browser_action": {
    "default_title": "Cyber Privacy Inspector",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "webRequest",
    "cookies",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cyberprivacyinspector@local.dev"
    }
  }
}